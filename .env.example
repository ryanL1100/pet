# Backend server
HOST=127.0.0.1
PORT=8787

# LongCat provider
# Keep the real key on the backend only. Do not expose it in frontend code.
LONGCAT_API_KEY=

# Official OpenAI-compatible base URL from LongCat docs.
# You can omit this unless LongCat gives you a different endpoint.
LONGCAT_BASE_URL=https://api.longcat.chat/openai

# Override when your LongCat account uses a different model id.
LONGCAT_MODEL=LongCat-2.0
LONGCAT_TIMEOUT_MS=20000

# LongCat supports thinking {"type":"enabled"} or {"type":"disabled"}.
LONGCAT_THINKING=disabled
